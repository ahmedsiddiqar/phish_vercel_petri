# ============================================================
# Petridish Phishing Tracker — Environment Variables
# Copy this to .env.local and fill in your values
# In Vercel: add these under Project Settings → Environment Variables
# ============================================================

# Supabase — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin panel password — change this to something strong!
ADMIN_PASSWORD=petridish-admin-2025
